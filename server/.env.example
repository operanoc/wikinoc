# Wiki NOC — IA Server variables de entorno
# Renombrá este archivo a .env (o seteá las variables en tu shell)

# === OBLIGATORIO ===
# Tu API key de Groq — obtenela en https://console.groq.com/keys
GROQ_API_KEY=gsk_tu_api_key_aqui

# === OPCIONAL ===
# Modelo a usar (default: llama-3.3-70b-versatile)
# Otros: llama-3.1-8b-instant (más rápido), mixtral-8x7b-32768, gemma2-9b-it
GROQ_MODEL=llama-3.3-70b-versatile

# Host y puerto donde escucha el servidor
WIKINOC_AI_HOST=127.0.0.1
WIKINOC_AI_PORT=8787

# Mostrar stack traces en errores (solo desarrollo)
# NODE_ENV=development
